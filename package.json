{
  "name": "malgrim",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:test": "MALGRIM_DISABLE_AZURE_OPENAI=true next dev -p 3100",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
