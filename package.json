  },
  "dependencies": {
    "@copilotkit/runtime": "^1.61.0",
    "mermaid": "^11.4.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  }
}
